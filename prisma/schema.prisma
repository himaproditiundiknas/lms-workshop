generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED

  @@map("user_status")
}

enum InvitationScope {
  WORKSHOP @map("workshop")
  COHORT   @map("cohort")

  @@map("invitation_scope")
}

enum InvitationCodeStatus {
  ACTIVE   @map("active")
  INACTIVE @map("inactive")
  EXPIRED  @map("expired")
  REVOKED  @map("revoked")

  @@map("invitation_code_status")
}

enum EnrollmentStatus {
  PENDING   @map("pending")
  APPROVED  @map("approved")
  REJECTED  @map("rejected")
  CANCELLED @map("cancelled")

  @@map("enrollment_status")
}

enum WorkshopStatus {
  DRAFT     @map("draft")
  PUBLISHED @map("published")
  ARCHIVED  @map("archived")

  @@map("workshop_status")
}

enum CohortStatus {
  ACTIVE   @map("active")
  INACTIVE @map("inactive")
  CLOSED   @map("closed")

  @@map("cohort_status")
}

enum SessionAttendanceStatus {
  NOT_OPENED @map("not_opened")
  OPEN       @map("open")
  CLOSED     @map("closed")

  @@map("session_attendance_status")
}

enum AttendanceStatus {
  PRESENT   @map("present")
  ABSENT    @map("absent")
  EXCUSED   @map("excused")
  CORRECTED @map("corrected")

  @@map("attendance_status")
}

enum AttendanceMethod {
  QR     @map("qr")
  MANUAL @map("manual")
  SYSTEM @map("system")

  @@map("attendance_method")
}

model User {
  id        String     @id @default(uuid()) @db.Uuid
  email     String     @unique
  googleSub String?    @unique @map("google_sub")
  status    UserStatus @default(ACTIVE)

  profile UserProfile?
  roles   UserRole[]

  createdInvitationCodes InvitationCode[]       @relation("InvitationCodeCreatedBy")
  invitationRedemptions  InvitationRedemption[]
  auditLogs              AuditLog[]             @relation("AuditLogActor")
  enrollments            Enrollment[]
  openedAttendances      Session[]              @relation("SessionAttendanceOpenedBy")
  closedAttendances      Session[]              @relation("SessionAttendanceClosedBy")
  attendances            Attendance[]
  recordedAttendances    Attendance[]           @relation("AttendanceRecordedBy")
  correctedAttendances   Attendance[]           @relation("AttendanceCorrectedBy")
  createdQrTokens        QrToken[]              @relation("QrTokenCreatedBy")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model UserProfile {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @unique @map("user_id") @db.Uuid
  fullName           String?   @map("full_name")
  avatarUrl          String?   @map("avatar_url")
  nim                String?
  programStudy       String?   @map("program_study")
  semester           Int?
  phone              String?
  bio                String?
  profileCompletedAt DateTime? @map("profile_completed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_profiles")
}

model Role {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @unique
  description String?

  users UserRole[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now()) @map("assigned_at")

  @@id([userId, roleId])
  @@map("user_roles")
}

model InvitationCode {
  id String @id @default(uuid()) @db.Uuid

  codeHash String @unique @map("code_hash")

  scope    InvitationScope
  targetId String          @map("target_id") @db.Uuid

  status    InvitationCodeStatus @default(ACTIVE)
  maxUses   Int                  @default(1) @map("max_uses")
  usedCount Int                  @default(0) @map("used_count")
  expiresAt DateTime?            @map("expires_at")

  createdById String? @map("created_by_id") @db.Uuid
  createdBy   User?   @relation("InvitationCodeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  redemptions InvitationRedemption[]
  enrollments Enrollment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([scope, targetId])
  @@index([status])
  @@index([expiresAt])
  @@map("invitation_codes")
}

model InvitationRedemption {
  id String @id @default(uuid()) @db.Uuid

  invitationCodeId String @map("invitation_code_id") @db.Uuid
  userId           String @map("user_id") @db.Uuid

  redeemedAt DateTime @default(now()) @map("redeemed_at")

  invitationCode InvitationCode @relation(fields: [invitationCodeId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([invitationCodeId, userId])
  @@index([userId])
  @@map("invitation_redemptions")
}

model AuditLog {
  id String @id @default(uuid()) @db.Uuid

  actorUserId String? @map("actor_user_id") @db.Uuid
  actorUser   User?   @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  action     String
  entityType String  @map("entity_type")
  entityId   String? @map("entity_id") @db.Uuid
  metadata   Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([actorUserId])
  @@index([action])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model Enrollment {
  id String @id @default(uuid()) @db.Uuid

  userId           String  @map("user_id") @db.Uuid
  invitationCodeId String? @map("invitation_code_id") @db.Uuid

  scope    InvitationScope
  targetId String           @map("target_id") @db.Uuid
  cohortId String?          @map("cohort_id") @db.Uuid
  status   EnrollmentStatus @default(PENDING)

  approvedAt      DateTime? @map("approved_at")
  rejectedAt      DateTime? @map("rejected_at")
  approvedById    String?   @map("approved_by_id") @db.Uuid
  rejectedById    String?   @map("rejected_by_id") @db.Uuid
  rejectionReason String?   @map("rejection_reason")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitationCode InvitationCode? @relation(fields: [invitationCodeId], references: [id], onDelete: SetNull)
  cohort         Cohort?         @relation(fields: [cohortId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, scope, targetId])
  @@index([status])
  @@index([scope, targetId])
  @@index([cohortId])
  @@map("enrollments")
}

model Workshop {
  id String @id @default(uuid()) @db.Uuid

  title       String
  slug        String         @unique
  description String?
  status      WorkshopStatus @default(DRAFT)

  cohorts Cohort[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("workshops")
}

model Cohort {
  id String @id @default(uuid()) @db.Uuid

  workshopId String @map("workshop_id") @db.Uuid

  name     String
  slug     String       @unique
  status   CohortStatus @default(ACTIVE)
  startsAt DateTime?    @map("starts_at")
  endsAt   DateTime?    @map("ends_at")

  workshop    Workshop     @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  sessions    Session[]
  enrollments Enrollment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([workshopId])
  @@index([status])
  @@map("cohorts")
}

model Session {
  id String @id @default(uuid()) @db.Uuid

  cohortId    String  @map("cohort_id") @db.Uuid
  title       String
  description String?
  location    String?
  meetingNo   Int     @map("meeting_no")

  startsAt DateTime? @map("starts_at")
  endsAt   DateTime? @map("ends_at")

  attendanceStatus   SessionAttendanceStatus @default(NOT_OPENED) @map("attendance_status")
  attendanceOpenedAt DateTime?               @map("attendance_opened_at")
  attendanceOpenedBy String?                 @map("attendance_opened_by") @db.Uuid
  attendanceClosedAt DateTime?               @map("attendance_closed_at")
  attendanceClosedBy String?                 @map("attendance_closed_by") @db.Uuid

  cohort Cohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)

  attendanceOpenedByUser User? @relation("SessionAttendanceOpenedBy", fields: [attendanceOpenedBy], references: [id], onDelete: SetNull)
  attendanceClosedByUser User? @relation("SessionAttendanceClosedBy", fields: [attendanceClosedBy], references: [id], onDelete: SetNull)

  qrTokens    QrToken[]
  attendances Attendance[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([cohortId, meetingNo])
  @@index([cohortId])
  @@index([attendanceStatus])
  @@map("sessions")
}

model QrToken {
  id String @id @default(uuid()) @db.Uuid

  sessionId String   @map("session_id") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")

  createdById String? @map("created_by_id") @db.Uuid

  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("QrTokenCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([sessionId])
  @@index([expiresAt])
  @@map("qr_tokens")
}

model Attendance {
  id String @id @default(uuid()) @db.Uuid

  sessionId String @map("session_id") @db.Uuid
  userId    String @map("user_id") @db.Uuid

  status AttendanceStatus @default(PRESENT)
  method AttendanceMethod

  checkedInAt DateTime @default(now()) @map("checked_in_at")

  recordedById  String?   @map("recorded_by_id") @db.Uuid
  correctedById String?   @map("corrected_by_id") @db.Uuid
  correctedAt   DateTime? @map("corrected_at")

  note String?

  session     Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  recordedBy  User?   @relation("AttendanceRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)
  correctedBy User?   @relation("AttendanceCorrectedBy", fields: [correctedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
  @@index([status])
  @@index([method])
  @@map("attendances")
}
